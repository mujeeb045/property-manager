<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">🏢 History by Unit</h1>
    <p class="text-gray-600 mb-8">Click on any unit to view its transaction history</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% units.forEach(unit=> { %>
            <div onclick="window.location.href='/history/unit/<%= unit.id %>'"
                class="bg-white rounded-2xl p-6 border border-gray-100 hover:border-emerald-400 hover:shadow-md cursor-pointer transition-all">
                <div class="flex justify-between items-start">
                    <div>
                        <strong class="text-lg">🏠 <%= unit.unit_name %></strong>
                        <p class="text-gray-600 mt-1">Rent: ₹<%= Number(unit.rent_amount).toLocaleString('en-IN') %>
                        </p>
                    </div>
                    <% if (unit.is_occupied) { %>
                        <span class="px-3 py-1 text-xs bg-emerald-100 text-emerald-700 rounded-full">Occupied</span>
                        <% } else { %>
                            <span class="px-3 py-1 text-xs bg-gray-100 text-gray-700 rounded-full">Vacant</span>
                            <% } %>
                </div>

                <% if (unit.tenant_name) { %>
                    <p class="text-sm text-gray-500 mt-3">Current Tenant: <%= unit.tenant_name %>
                    </p>
                    <% } %>
            </div>
            <% }) %>
    </div>
</div>