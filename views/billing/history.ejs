<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">📜 History & Details</h1>
    <p class="text-gray-600 mb-6">Tap on any tenant to view full history</p>

    <% if (error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-6 py-4 rounded-2xl mb-6">
            <%= error %>
        </div>
        <% } %>

            <div class="mb-6">
                <input type="text" id="tenantSearch" placeholder="Search tenants..." onkeyup="filterTenants()"
                    class="w-full border border-gray-300 rounded-2xl px-5 py-4 text-base focus:outline-none">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="tenantList">
                <%- tenantListHTML %>
            </div>
</div>

<script>
    function filterTenants() {
        const filter = document.getElementById("tenantSearch").value.toLowerCase();
        const cards = document.getElementsByClassName("tenant-card");
        for (let card of cards) {
            card.style.display = card.textContent.toLowerCase().includes(filter) ? "" : "none";
        }
    }
</script>