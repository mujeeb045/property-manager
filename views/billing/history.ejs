<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">📖 History & Details</h1>

    <div class="mb-8">
        <input type="text" id="tenantSearch" placeholder="Search by tenant name..." onkeyup="filterTenants()"
            class="w-full border border-gray-300 rounded-2xl px-6 py-4 text-lg focus:outline-none focus:border-emerald-500">
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="tenantList">
        <%- tenantListHTML %>
    </div>

    <div id="tenantDetail" class="hidden bg-white rounded-3xl p-8 shadow-sm mt-8">
        <button onclick="hideDetail()" class="mb-6 text-emerald-600 hover:underline">← Back to List</button>

        <h2 class="text-3xl font-bold mb-1" id="detailName"></h2>
        <p class="text-gray-600 mb-8" id="detailUnit"></p>

        <div class="grid grid-cols-2 gap-6 text-sm">
            <div><strong>Father:</strong> <span id="detailFather"></span></div>
            <div><strong>Phone:</strong> <span id="detailPhone"></span></div>
            <div><strong>Aadhaar:</strong> <span id="detailAadhaar"></span></div>
            <div><strong>Deposit:</strong> <span id="detailDeposit"></span></div>
        </div>
    </div>
</div>

<script>
    var allTenants = <% - JSON.stringify(tenantsData || []) %>;

    function filterTenants() {
        var filter = document.getElementById("tenantSearch").value.toLowerCase();
        var cards = document.getElementsByClassName("tenant-card");
        for (var i = 0; i < cards.length; i++) {
            var name = (cards[i].getAttribute("data-name") || "").toLowerCase();
            cards[i].style.display = name.indexOf(filter) !== -1 ? "" : "none";
        }
    }

    function showTenantDetailFromId(id) {
        for (var i = 0; i < allTenants.length; i++) {
            if (allTenants[i].id == id) {
                var t = allTenants[i];
                document.getElementById("tenantDetail").classList.remove("hidden");
                document.getElementById("detailName").innerHTML = t.name;
                document.getElementById("detailUnit").innerHTML = t.unit_name || "No Unit";
                document.getElementById("detailFather").innerHTML = t.father_name || "N/A";
                document.getElementById("detailPhone").innerHTML = t.phone || "N/A";
                document.getElementById("detailAadhaar").innerHTML = t.id_card_no || "N/A";
                document.getElementById("detailDeposit").innerHTML = t.security_deposit
                    ? "₹" + Number(t.security_deposit).toLocaleString('en-IN')
                    : "N/A";
                return;
            }
        }
    }

    function hideDetail() {
        document.getElementById("tenantDetail").classList.add("hidden");
    }
</script>