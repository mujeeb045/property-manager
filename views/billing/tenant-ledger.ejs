<div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold">👤 <%= tenant.name %>
            </h1>
            <p class="text-gray-600">Unit <%= tenant.unit_name %> • <%= selectedMonth %>
            </p>
        </div>
        <a href="/tenants?month=<%= selectedMonth %>" class="text-emerald-600 hover:underline">← Back to All Tenants</a>
    </div>

    <!-- Summary Card -->
    <div class="bg-white rounded-3xl p-8 mb-8 shadow-sm">
        <div class="grid grid-cols-3 gap-8 text-center">
            <div>
                <p class="text-gray-500 text-sm">Total Billed</p>
                <p class="text-3xl font-bold text-gray-800">₹<%= totalBilled.toLocaleString('en-IN') %>
                </p>
            </div>
            <div>
                <p class="text-gray-500 text-sm">Received</p>
                <p class="text-3xl font-bold text-emerald-600">₹<%= totalReceived.toLocaleString('en-IN') %>
                </p>
            </div>
            <div>
                <p class="text-gray-500 text-sm">Balance</p>
                <p class="text-3xl font-bold <%= balance >= 0 ? 'text-red-600' : 'text-blue-600' %>">₹<%=
                        Math.abs(balance).toLocaleString('en-IN') %>
                </p>
            </div>
        </div>
    </div>

    <!-- Current Month Breakdown -->
    <div class="bg-white rounded-3xl p-8 mb-8">
        <h2 class="text-xl font-semibold mb-6">📊 Current Month: <%= selectedMonth %>
        </h2>
        <div class="space-y-4">
            <% breakdown.forEach(item=> { %>
                <div class="flex justify-between items-center py-3 border-b last:border-0">
                    <span>
                        <%= item.desc %>
                    </span>
                    <span class="font-medium">₹<%= item.amount.toLocaleString('en-IN') %></span>
                </div>
                <% }) %>
        </div>
    </div>

    <!-- Full Payment History -->
    <div class="bg-white rounded-3xl p-8">
        <h2 class="text-xl font-semibold mb-6">📜 Payment History</h2>
        <% if (payments.length> 0) { %>
            <div class="space-y-4">
                <% payments.forEach(p=> { %>
                    <div class="flex justify-between items-center bg-gray-50 p-5 rounded-2xl">
                        <div>
                            <div class="font-medium">
                                <%= p.billing_month %>
                            </div>
                            <div class="text-sm text-gray-500">
                                <%= new Date(p.payment_date).toLocaleDateString('en-IN') %>
                            </div>
                        </div>
                        <div class="text-emerald-600 font-semibold text-xl">₹<%=
                                Number(p.amount_paid).toLocaleString('en-IN') %>
                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <p class="text-gray-500 py-8 text-center">No payments recorded yet.</p>
                <% } %>
    </div>

    <!-- WhatsApp Buttons -->
    <div class="flex gap-4 mt-10">
        <a href="<%= whatsappInvoiceLink %>" target="_blank"
            class="flex-1 bg-green-500 hover:bg-green-600 text-white text-center py-5 rounded-2xl font-medium text-lg">
            📱 Send Current Invoice
        </a>
    </div>
</div>