<div class="max-w-6xl mx-auto px-4 py-6">
    <a href="/history/units" class="inline-flex items-center gap-2 text-emerald-600 hover:underline mb-6">← Back to
        Units</a>

    <div class="bg-white rounded-3xl p-8 shadow-sm">

        <!-- Unit Header -->
        <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold">🏠 <%= unit.unit_name %>
                </h1>
                <p class="text-xl text-gray-600 mt-1">
                    Rent: ₹<%= Number(unit.rent_amount).toLocaleString('en-IN') %>
                        | Maintenance: ₹<%= Number(unit.maintenance_amount || 0).toLocaleString('en-IN') %>
                </p>
            </div>

            <% if (unit.is_occupied && unit.tenant_id) { %>
                <a href="/history/tenant/<%= unit.tenant_id %>"
                    class="bg-emerald-600 hover:bg-emerald-700 text-white px-8 py-4 rounded-2xl font-medium flex items-center justify-center gap-2 w-full md:w-auto">
                    View Tenant History
                </a>
                <% } %>
        </div>

        <!-- Current Tenant Info -->
        <% if (unit.tenant_id) { %>
            <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-6 mb-8">
                <h3 class="font-semibold text-emerald-800 mb-2">Current Tenant</h3>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <p class="font-medium text-lg">
                            <%= unit.tenant_name %>
                        </p>
                        <p class="text-sm text-gray-600">+91 <%= unit.tenant_phone || 'N/A' %>
                        </p>
                    </div>
                    <a href="/history/tenant/<%= unit.tenant_id %>"
                        class="text-emerald-600 hover:text-emerald-700 font-medium">
                        View Full Tenant History →
                    </a>
                </div>
            </div>
            <% } else { %>
                <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 mb-8">
                    <p class="text-gray-600">This unit is currently <strong>vacant</strong>.</p>
                </div>
                <% } %>

                    <!-- Transaction History -->
                    <h3 class="text-xl font-semibold mb-4">Transaction History</h3>

                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[700px]">
                            <thead>
                                <tr class="border-b-2 border-gray-300">
                                    <th class="text-left py-4">Date</th>
                                    <th class="text-left py-4">Particular</th>
                                    <th class="text-right py-4">Amount</th>
                                    <th class="text-right py-4">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <%- rowsHTML %>
                            </tbody>
                        </table>
                    </div>

                    <% if (unit.is_occupied && unit.tenant_id) { %>
                        <div class="mt-8">
                            <a href="/history/tenant/<%= unit.tenant_id %>"
                                class="inline-block bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-2xl font-medium">
                                Go to Full Tenant History →
                            </a>
                        </div>
                        <% } %>

    </div>
</div>