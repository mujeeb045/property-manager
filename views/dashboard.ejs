<div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-2">Dashboard</h1>
    <p class="text-gray-600 mb-8">
        <%= currentMonth %>
    </p>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
            <div class="text-sm text-gray-500">Total Due</div>
            <div class="text-4xl font-bold text-red-600 mt-3">
                ₹<%= stats.totalDue.toLocaleString('en-IN') %>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
            <div class="text-sm text-gray-500">Collected This Month</div>
            <div class="text-4xl font-bold text-emerald-600 mt-3">
                ₹<%= stats.collectedThisMonth.toLocaleString('en-IN') %>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
            <div class="text-sm text-gray-500">Active Tenants</div>
            <div class="text-4xl font-bold text-blue-600 mt-3">
                <%= stats.totalActiveTenants %>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
            <div class="text-sm text-gray-500">Occupied Units</div>
            <div class="text-4xl font-bold text-purple-600 mt-3">
                <%= stats.occupiedUnits %> / <%= stats.totalUnits %>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/tenants"
            class="bg-white hover:bg-emerald-50 border border-gray-200 hover:border-emerald-200 rounded-2xl p-6 transition-all">
            <div class="text-2xl mb-3">💰</div>
            <div class="font-semibold">Rent Collection</div>
        </a>

        <a href="/add-unit"
            class="bg-white hover:bg-blue-50 border border-gray-200 hover:border-blue-200 rounded-2xl p-6 transition-all">
            <div class="text-2xl mb-3">🏢</div>
            <div class="font-semibold">Units</div>
        </a>

        <a href="/history/tenants"
            class="bg-white hover:bg-amber-50 border border-gray-200 hover:border-amber-200 rounded-2xl p-6 transition-all">
            <div class="text-2xl mb-3">📜</div>
            <div class="font-semibold">Tenant History</div>
        </a>

        <a href="/settings"
            class="bg-white hover:bg-purple-50 border border-gray-200 hover:border-purple-200 rounded-2xl p-6 transition-all">
            <div class="text-2xl mb-3">⚙️</div>
            <div class="font-semibold">Settings</div>
        </a>
    </div>
</div>