<h1 class="text-4xl font-bold mb-8 text-gray-800">🏠 Dashboard</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-lg font-medium text-gray-600">Total Units</h3>
        <p class="text-5xl font-bold text-blue-600 mt-3">
            <%= total_units %>
        </p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-lg font-medium text-gray-600">Occupied Units</h3>
        <p class="text-5xl font-bold text-emerald-600 mt-3">
            <%= occupied_units %>
        </p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-lg font-medium text-gray-600">Vacant Units</h3>
        <p class="text-5xl font-bold text-amber-600 mt-3">
            <%= vacant_units %>
        </p>
    </div>
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <a href="/register-tenant"
        class="bg-emerald-600 hover:bg-emerald-700 text-white p-8 rounded-2xl text-center text-xl font-semibold shadow transition">
        👤 Register New Tenant
    </a>

    <a href="/add-unit"
        class="bg-blue-600 hover:bg-blue-700 text-white p-8 rounded-2xl text-center text-xl font-semibold shadow transition">
        🏢 Add / Manage Units
    </a>
</div>

<div class="mt-12 bg-white p-8 rounded-2xl shadow">
    <h2 class="text-2xl font-semibold mb-6">Generate Monthly Bills</h2>
    <form method="POST" action="/generate-monthly-invoices" class="flex gap-4 items-end">
        <div>
            <label class="block text-sm font-medium mb-2">Month</label>
            <select name="month" class="border border-gray-300 rounded-lg px-4 py-3 w-48">
                <%- monthOptionsHTML %>
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium mb-2">Year</label>
            <input type="number" name="year" value="<%= currentYear %>"
                class="border border-gray-300 rounded-lg px-4 py-3 w-32">
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-medium">
            Generate Bills
        </button>
    </form>
</div>