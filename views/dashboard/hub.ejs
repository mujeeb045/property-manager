<h1 class="text-3xl md:text-4xl font-bold mb-8 text-gray-800">🏠 Dashboard</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mb-10">
    <div class="bg-white p-6 rounded-2xl shadow card">
        <h3 class="text-sm font-medium text-gray-600">Total Units</h3>
        <p class="text-4xl md:text-5xl font-bold text-blue-600 mt-3">
            <%= total_units %>
        </p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow card">
        <h3 class="text-sm font-medium text-gray-600">Occupied</h3>
        <p class="text-4xl md:text-5xl font-bold text-emerald-600 mt-3">
            <%= occupied_units %>
        </p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow card">
        <h3 class="text-sm font-medium text-gray-600">Vacant</h3>
        <p class="text-4xl md:text-5xl font-bold text-amber-600 mt-3">
            <%= vacant_units %>
        </p>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <a href="/register-tenant"
        class="bg-emerald-600 hover:bg-emerald-700 text-white p-6 md:p-8 rounded-3xl text-center text-lg font-semibold shadow transition">
        👤 Register New Tenant
    </a>
    <a href="/add-unit"
        class="bg-blue-600 hover:bg-blue-700 text-white p-6 md:p-8 rounded-3xl text-center text-lg font-semibold shadow transition">
        🏢 Manage Units
    </a>
</div>

<div class="mt-10 text-center">
    <a href="/settings"
        class="inline-block bg-purple-600 hover:bg-purple-700 text-white px-8 py-4 rounded-2xl text-base font-medium">
        ⚙️ Generate Monthly Bills
    </a>
</div>