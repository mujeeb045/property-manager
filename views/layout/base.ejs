<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Property Manager - <%- title || 'Dashboard' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .sidebar {
            width: 260px;
            background: #1f2937;
            color: white;
            transition: all 0.3s;
        }

        .main-content {
            transition: all 0.3s;
        }

        @media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: -260px;
                height: 100vh;
                z-index: 50;
            }

            .sidebar.open {
                left: 0;
            }
        }

        table {
            width: 100%;
        }

        .card {
            transition: all 0.2s;
        }
    </style>
</head>

<body class="bg-gray-100">
    <!-- Sidebar -->
    <nav id="sidebar" class="sidebar p-4 fixed h-screen overflow-y-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold">🏠 Property Manager</h1>
            <button onclick="toggleSidebar()" class="md:hidden text-3xl leading-none">✕</button>
        </div>

        <div class="space-y-1 text-sm">
            <a href="/" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">📊 Dashboard</a>
            <a href="/add-unit" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">🏢 Units</a>
            <a href="/tenants" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">💰 This Month Collection</a>
            <a href="/history/tenants" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">📜 History by
                Tenant</a>
            <a href="/history/units" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">🏢 History by Unit</a>
            <a href="/manage-profiles" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">👥 Manage Tenants</a>
            <a href="/settings" class="nav-link block py-3 px-4 hover:bg-gray-700 rounded">⚙️ Settings</a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content md:ml-[260px] min-h-screen">
        <div class="max-w-7xl mx-auto p-4 md:p-6">
            <!-- Mobile Header -->
            <div class="md:hidden flex justify-between items-center mb-6 bg-white p-4 rounded-2xl shadow">
                <button onclick="toggleSidebar()" class="text-3xl">☰</button>
                <h1 class="text-xl font-semibold">Property Manager</h1>
            </div>

            <%- body %>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
        }
    </script>
</body>

</html>