<h1 class="text-3xl font-bold mb-8">👤 Register New Tenant</h1>

<% if (error) { %>
    <div class="bg-red-100 text-red-700 p-4 rounded-xl mb-6">
        <%= error %>
    </div>
    <% } %>

        <div class="max-w-2xl mx-auto bg-white p-6 md:p-8 rounded-3xl shadow">
            <form method="POST" action="/allocate-tenant" class="space-y-6">
                <!-- All form fields remain same, just better spacing -->
                <div>
                    <label class="block text-sm font-medium mb-2">Select Units (You can select multiple)</label>
                    <select name="unitIds" multiple required
                        class="w-full border border-gray-300 rounded-2xl px-4 py-3 h-40">
                        <% vacantUnits.rows.forEach(u=> { %>
                            <option value="<%= u.id %>">
                                <%= u.unit_name %> — Rent: ₹<%= Number(u.rent_amount).toLocaleString('en-IN') %>
                            </option>
                            <% }) %>
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Hold Ctrl (Windows) or Cmd (Mac) to select multiple units</p>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Tenant Full Name</label>
                    <input type="text" name="tenantName" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Father's Name</label>
                    <input type="text" name="fatherName" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-2">Phone Number</label>
                        <input type="text" name="phone" required
                            class="w-full border border-gray-300 rounded-lg px-4 py-3">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Alternate Phone</label>
                        <input type="text" name="altPhone" class="w-full border border-gray-300 rounded-lg px-4 py-3">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Aadhaar / ID Card No</label>
                    <input type="text" name="idCardNo" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Security Deposit (₹)</label>
                    <input type="number" name="securityDeposit" value="0"
                        class="w-full border border-gray-300 rounded-lg px-4 py-3">
                </div>

                <button type="submit"
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-4 rounded-2xl text-lg">
                    Allocate Tenant & Start Billing
                </button>
            </form>
        </div>